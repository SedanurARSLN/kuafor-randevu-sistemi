# Veritabani baglanti URL'si (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/randevu_db

# JWT ayarlari
JWT_SECRET=your-super-secret-key-change-this
JWT_EXPIRES_IN=7d

# Sunucu portu
PORT=3000

# CORS - izin verilen originler (virgülle ayrılmış)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# Stripe ödeme (stripe.com'dan alinir)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# E-posta (şifre sıfırlama için)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
